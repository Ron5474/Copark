{
  "name": "copark-e2etest",
  "type": "module",
  "version": "4.0.0",
  "description": "COPARK - End to End Test",
  "author": "Copark Inc. <coparkspace@gmail.com>",
  "license": "UNLICENSED",
  "repository": "none",
  "devDependencies": {
    "dotenv": "*",
    "eslint": "*",
    "eslint-config-google": "*",
    "eslint-plugin-jsdoc": "*",
    "express": "*",
    "puppeteer": "*",
    "supertest": "*",
    "vite-plugin-eslint": "*",
    "vitest": "*"
  },
  "scripts": {
    "docker": "docker compose -f ../docker-compose.db.yml --profile dev down && docker compose -f ../docker-compose.db.yml --profile dev up -d",
    "build": "cd ../frontend && npm run build",
    "run-dev": "cd ../ && npm run dev",
    "e2e": "vitest run --no-file-parallelism --testTimeout=3000",
    "test": "(npm run dev-root) && (npm run docker) && (npm run e2e)",
    "lint": "eslint test --no-inline-config --max-warnings 0"
  },
  "dependencies": {
    "@playwright/test": "^1.52.0",
    "playwright": "^1.52.0",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1"
  }
}
