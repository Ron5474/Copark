{
  "name": "microservices",
  "version": "1.0.0",
  "scripts": {
    "bstart": "npm run build && npm run start",
    "start": "node build/server.js",
    "build": "tsc",
    "dev": "nodemon",
    "test": "vitest run --no-file-parallelism --testTimeout=3000 --coverage",
    "lint": "eslint src/**/*.[jt]s --fix"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^4.18.4",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^6.4.17",
    "@vitest/coverage-v8": "^3.1.3",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3",
    "vitest": "^3.1.2",
    "supertest": "^7.1.0"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "ts-node ./src/server.ts"
  }
}
