{
    "name": "copark-containerised",
    "version": "1.0.0",
    "description": "Copark WebApp",
    "author": "Copark Inc.",
    "license": "UNLICENSED",
    "repository": "none",
    "scripts": {
      "package": "docker build . -t cte-linux-amd64 --platform linux/amd64 && docker save -o cte-linux-amd64.tar cte-linux-amd64",
      "containerised": "npm run build && npm run compose",
      "compose": "docker compose up --build",
      "installs": "npm install && npm run install-auth && npm run install-admin && npm run install-enforcement && npm run install-driver",
      "install-auth": "cd microservice/AuthService && npm install",
      "install-admin": "cd app/admin && npm install",
      "install-enforcement": "cd app/enforcement && npm install",
      "install-driver": "cd app/driver && npm install",
      "cis": "npm ci && npm run ci-auth",
      "ci-auth": "cd microservice/AuthService && npm ci",
      "build": "npm run build-auth && npm run build-admin && npm run build-enforcement && npm run build-driver",
      "build-auth": "cd microservice/AuthService && npm run build",
      "build-admin": "cd app/admin && npm run build",
      "build-enforcement": "cd app/enforcement && npm run build",
      "build-driver": "cd app/driver && npm run build",
      "start": "concurrently --kill-others \"npm run start-auth\"",
      "start-auth": "cd microservice/AuthService && npm start",
      "lint": "npm run lint-auth && npm run lint-admin && npm run lint-enforcement && npm run lint-driver",
      "lint-auth": "cd microservice/AuthService && npm run lint",
      "lint-admin": "cd app/admin && npm run lint",
      "lint-enforcement": "cd app/enforcement && npm run lint",
      "lint-driver": "cd app/driver && npm run lint",
      "test": "npm run test-driver",
      "test-driver": "cd app/driver && npm run test"
    },
    "devDependencies": {
      "concurrently": "*"
    }
  }